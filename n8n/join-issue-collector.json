        "text": "=E-Mail Betreff: {{ $('Email Trigger (IMAP)').first().json.subject }}\nE-Mail Body: {{ $('Email Trigger (IMAP)').first().json.textPlain }}",
        "messages": {
          "messageValues": [
            {
              "message": "Du bist ein Assistent, der E-Mails in strukturierte Tickets umwandelt. Analysiere diese E-Mail und antworte NUR mit einem validen JSON-Objekt (kein Markdown, keine Erklärung, kein Text darum):\n\n{\"title\": \"Prägnanter Titel (max 60 Zeichen)\", \"description\": \"Vollständige Beschreibung\", \"category\": \"Technical Task oder User Story\", \"priority\": \"urgent oder medium oder low\", \"due_date\": \"YYYY-MM-DD oder null\"}\n\nRegeln für priority:\n- urgent: Wörter wie dringend, kritisch, sofort, asap, urgent\n- low: Wörter wie irgendwann, nice to have, optional\n- medium: alles andere"
            }
          ]
        },
        "batching": {}
      },
