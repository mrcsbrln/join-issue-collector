    {
      "parameters": {
        "jsCode": "const output = $input.first().json;\nconst raw = output.text ?? output.output ?? output.response ?? JSON.stringify(output);\nconst jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) throw new Error(\"No JSON found in LLM response\");\n\nconst parsed = JSON.parse(jsonMatch[0]);\n\nconst fromRaw = $('Email Trigger (IMAP)').first().json.from;\nconst creator_email = typeof fromRaw === 'string'\n  ? (fromRaw.match(/<(.+?)>/) || [null, fromRaw])[1]\n  : fromRaw?.value?.[0]?.address;\n\nreturn [{\n  json: {\n    title: parsed.title,\n    description: parsed.description ?? \"\",\n    category: parsed.category,\n    priority: parsed.priority,\n    due_date: parsed.due_date ?? null,\n    creator_email\n  }\n}];"
      },
